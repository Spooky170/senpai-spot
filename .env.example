# ============================================================
#  Senpai Spot — Environment Variables
# ============================================================

# --- Blogger / Blogspot ---
# Your Blogspot blog URL (without trailing slash)
NEXT_PUBLIC_BLOGGER_URL=https://yourblog.blogspot.com

# Google Blogger API Key (get it from Google Cloud Console)
# Needed only if you use the Blogger API directly.
# The RSS feed approach works WITHOUT this key.
BLOGGER_API_KEY=your_blogger_api_key_here

# Your Blogger Blog ID (find it in Blogger Settings > Basic)
BLOGGER_BLOG_ID=your_blog_id_here

# --- Site Config ---
NEXT_PUBLIC_SITE_URL=https://senpaispot.com
NEXT_PUBLIC_SITE_NAME=Senpai Spot
NEXT_PUBLIC_SITE_DESCRIPTION=Your ultimate anime blog — news, reviews, manga, and more.

# --- Google Analytics (optional) ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Social Links ---
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/senpaispot
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/senpaispot
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@senpaispot
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/senpaispot
